DISCORD_TOKEN=your-discord-token-here
CLIENT_ID=your-client-id-here
GUILD_ID=your-guild-id-here
GEMINI_API_KEY_FREE=your-free-gemini-api-key-here
GEMINI_API_KEY_PAID=your-paid-gemini-api-key-here
HORRIBLESCOPE_CHANNEL=off-topic
GENERAL_CHANNEL=general
FREE_TIER_MODE=true
# Your Discord user ID (right-click your name → Copy User ID in Discord)
OWNER_ID=your-discord-user-id-here
# Optional: store DB outside the repo so git pull never wipes it
# DB_PATH=/home/yourname/astro_bot.db
# Partner bot API — share this key + your VM's external IP + port 8080 with the other bot owner
PARTNER_BOT_API_KEY=change-me-to-a-random-secret
# Optional: override the default API server port (default 8080)
# API_SERVER_PORT=8080