[Unit]
Description=Bamboozled — Chaos Trivia Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sreekuttanjayakumar97
WorkingDirectory=/home/sreekuttanjayakumar97/disco_bot/bamboozled
EnvironmentFile=/home/sreekuttanjayakumar97/disco_bot/bamboozled/.env
ExecStart=/home/sreekuttanjayakumar97/disco_bot/.venv/bin/python bot.py
Restart=on-failure
RestartSec=10
StandardOutput=append:/home/sreekuttanjayakumar97/disco_bot/bamboozled/logs/bot.log
StandardError=append:/home/sreekuttanjayakumar97/disco_bot/bamboozled/logs/bot.log

[Install]
WantedBy=multi-user.target
